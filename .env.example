# ===== Mezon Bot =====
# Lấy từ Mezon Developer Portal → Thông tin chung
APPLICATION_ID=your_bot_id_here
APPLICATION_TOKEN=your_bot_token_here

# Prefix bot — mặc định là dấu sao
BOT_PREFIX=*

# ===== Database (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===== Application =====
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=info
