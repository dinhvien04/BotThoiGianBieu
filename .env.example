# ===== Mezon Bot =====
# Lấy từ Mezon Developer Portal → Thông tin chung
APPLICATION_ID=your_bot_id_here
APPLICATION_TOKEN=your_bot_token_here

# Prefix bot — mặc định là dấu sao
BOT_PREFIX=*
BOT_ENABLED=true
BOT_RETRY_DELAY_MS=60000
MEZON_TIMEOUT_MS=30000
MEZON_SOCKET_TIMEOUT_MS=20000
LOCAL_CONSOLE_ENABLED=false
LOCAL_USER_ID=local-dev-user
LOCAL_USERNAME=localdev
LOCAL_DISPLAY_NAME=Local Dev
LOCAL_CHANNEL_ID=local-channel
LOCAL_CLAN_ID=local-clan

# ===== Mezon Web Login =====
# If empty, backend falls back to APPLICATION_ID/APPLICATION_TOKEN.
MEZON_CLIENT_ID=
MEZON_CLIENT_SECRET=
MEZON_REDIRECT_URI=http://localhost:3001/auth/mezon/callback
MEZON_OAUTH_SCOPE=openid offline
MEZON_APP_SECRET=
AUTH_TOKEN_SECRET=
AUTH_COOKIE_DOMAIN=
MEZON_CHANNEL_AUTH_MAX_AGE_SECONDS=86400

# ===== Database (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===== Application =====
PORT=3001
WEB_APP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=info
