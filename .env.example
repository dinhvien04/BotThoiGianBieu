# ===== Mezon Bot =====
# From Mezon Developer Portal -> General information
APPLICATION_ID=your_bot_id_here
APPLICATION_TOKEN=your_bot_token_here

# Bot command prefix
BOT_PREFIX=*
BOT_ENABLED=true
BOT_RETRY_DELAY_MS=60000
MEZON_TIMEOUT_MS=30000
MEZON_SOCKET_TIMEOUT_MS=20000
LOCAL_CONSOLE_ENABLED=false
LOCAL_USER_ID=local-dev-user
LOCAL_USERNAME=localdev
LOCAL_DISPLAY_NAME=Local Dev
LOCAL_CHANNEL_ID=local-channel
LOCAL_CLAN_ID=local-clan

# ===== Database (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===== Application =====
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh
LOG_LEVEL=info

# ===== Web/API Auth =====
PORT=3001
WEB_APP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# URL public của web (dùng cho metadata SEO, sitemap, OpenGraph). Production phải đặt URL thật.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MEZON_REDIRECT_URI=http://localhost:3001/auth/mezon/callback
MEZON_OAUTH_SCOPE=openid offline
MEZON_CLIENT_ID=your_web_oauth_client_id_here
MEZON_CLIENT_SECRET="your_web_oauth_client_secret_here"
